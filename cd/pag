#!/bin/bash
set -e

# =====================
# CONFIG
# =====================
DB_USER="paymenter"
DB_PASS="yourPassword"
DB_NAME="paymenter"

APP_DIR="/var/www/paymenter"
SERVICE_FILE="/etc/systemd/system/paymenter.service"
CERT_DIR="/etc/certs/paymenter"
NGINX_CONF="/etc/nginx/sites-available/paymenter.conf"

# =====================
# DOMAIN INPUT
# =====================
read -rp "Enter your domain name (e.g., example.com): " DOMAIN

if [[ -z "$DOMAIN" ]]; then
    echo "❌ Domain cannot be empty!"
    exit 1
fi

# =====================
# OS CHECK
# =====================
if [ -f /etc/os-release ]; then
    . /etc/os-release
    echo "✅ Detected OS: $NAME $VERSION_ID"
else
    echo "❌ Cannot detect OS"
    exit 1
fi

# =====================
# SYSTEM UPDATE
# =====================
echo "📦 Updating system..."
apt update -y && apt upgrade -y

apt -y install \
software-properties-common curl apt-transport-https ca-certificates gnupg lsb-release \
unzip git cron openssl sudo

# =====================
# MARIADB REPO
# =====================
curl -sSL https://downloads.mariadb.com/MariaDB/mariadb_repo_setup | sudo bash -s -- --mariadb-server-version="mariadb-10.11"

# =====================
# PHP REPO
# =====================
LC_ALL=C.UTF-8 add-apt-repository -y ppa:ondrej/php

apt update -y

# =====================
# INSTALL PACKAGES
# =====================
apt -y install \
php8.3 php8.3-cli php8.3-fpm php8.3-common php8.3-mysql php8.3-mbstring php8.3-bcmath php8.3-xml php8.3-curl php8.3-zip php8.3-intl php8.3-gd php8.3-redis \
mariadb-server nginx redis-server tar unzip git

systemctl enable --now php8.3-fpm

# =====================
# COMPOSER
# =====================
curl -sS https://getcomposer.org/installer | php
mv composer.phar /usr/local/bin/composer

# =====================
# APP DOWNLOAD
# =====================
mkdir -p $APP_DIR
cd $APP_DIR

curl -Lo paymenter.tar.gz https://github.com/paymenter/paymenter/releases/latest/download/paymenter.tar.gz
tar -xzf paymenter.tar.gz
rm -f paymenter.tar.gz

# =====================
# PERMISSIONS (FIXED)
# =====================
chown -R www-data:www-data $APP_DIR
chmod -R 775 storage bootstrap/cache || true

# =====================
# COMPOSER INSTALL
# =====================
composer install --no-dev --optimize-autoloader --no-interaction --prefer-dist || true

# =====================
# DB CONFIG
# =====================
echo "📦 Setting up database..."

mysql <<MYSQL_SCRIPT
CREATE DATABASE IF NOT EXISTS ${DB_NAME};
CREATE USER IF NOT EXISTS '${DB_USER}'@'localhost' IDENTIFIED BY '${DB_PASS}';
GRANT ALL PRIVILEGES ON ${DB_NAME}.* TO '${DB_USER}'@'localhost';
FLUSH PRIVILEGES;
MYSQL_SCRIPT

# =====================
# LARAVEL SETUP
# =====================
cp .env.example .env

sed -i "s/DB_DATABASE=.*/DB_DATABASE=$DB_NAME/" .env
sed -i "s/DB_USERNAME=.*/DB_USERNAME=$DB_USER/" .env
sed -i "s/DB_PASSWORD=.*/DB_PASSWORD=$DB_PASS/" .env

php artisan key:generate --force || true
php artisan storage:link || true
php artisan migrate --force --seed || true
php artisan app:init || true

# =====================
# CRON FIX
# =====================
CRON_JOB="* * * * * php $APP_DIR/artisan schedule:run >> /dev/null 2>&1"

( crontab -l 2>/dev/null | grep -Fq "$APP_DIR/artisan schedule:run" ) || \
( crontab -l 2>/dev/null; echo "$CRON_JOB" ) | crontab -

systemctl enable cron
systemctl restart cron

# =====================
# QUEUE SERVICE
# =====================
cat > $SERVICE_FILE <<EOL
[Unit]
Description=Paymenter Queue Worker
After=network.target

[Service]
User=www-data
Group=www-data
Restart=always
ExecStart=/usr/bin/php $APP_DIR/artisan queue:work --sleep=3 --tries=3
RestartSec=5

[Install]
WantedBy=multi-user.target
EOL

systemctl daemon-reload
systemctl enable --now paymenter.service
systemctl enable --now redis-server

# =====================
# SSL (SELF SIGNED SAFE)
# =====================
mkdir -p $CERT_DIR

openssl req -x509 -nodes -days 3650 -newkey rsa:4096 \
-subj "/C=NA/ST=NA/L=NA/O=Shadow/CN=$DOMAIN" \
-keyout $CERT_DIR/privkey.pem \
-out $CERT_DIR/fullchain.pem

# =====================
# NGINX (FIXED SAFE)
# =====================
cat > $NGINX_CONF <<EOL
server {
    listen 80;
    server_name $DOMAIN;
    return 301 https://\$host\$request_uri;
}

server {
    listen 443 ssl http2;
    server_name $DOMAIN;

    root $APP_DIR/public;
    index index.php;

    ssl_certificate $CERT_DIR/fullchain.pem;
    ssl_certificate_key $CERT_DIR/privkey.pem;

    location / {
        try_files \$uri \$uri/ /index.php?\$query_string;
    }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass unix:/var/run/php/php8.3-fpm.sock;
        fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
    }
}
EOL

ln -sf $NGINX_CONF /etc/nginx/sites-enabled/paymenter.conf
systemctl restart nginx

# =====================
# FINAL FIX
# =====================
chown -R www-data:www-data $APP_DIR

# =====================
# CREATE USER
# =====================
cd $APP_DIR
php artisan app:user:create || true

# =====================
# OUTPUT
# =====================
echo "===================================="
echo "✅ INSTALL COMPLETE - SHADOW"
echo "🌐 https://$DOMAIN"
echo "🗄 DB: $DB_NAME"
echo "👤 USER: $DB_USER"
echo "🔑 PASS: $DB_PASS"
echo "📁 PATH: $APP_DIR"
echo "===================================="
